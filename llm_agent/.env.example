# RouterAI API Key
# Get your API key from https://routerai.ru
ROUTERAPI_API_KEY=your_api_key_here
# Optional: common keys loaded by script.py
API_KEY=your_api_key_here

# API
BASE_URL=https://routerai.ru/api/v1

# Модель по умолчанию
DEFAULT_MODEL=inception/mercury-coder
DEFAULT_MAX_TOKENS=
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=0.9
DEFAULT_TOP_K=50

# Стоимость токенов
USD_PER_1K_TOKENS=0.0015
RUB_PER_USD=100.0

# Управление контекстом
CONTEXT_RECENT_MESSAGES=10
CONTEXT_SUMMARY_INTERVAL=10

# Хранение
DIALOGUES_DIR=dialogues
DEFAULT_PROFILE=default

# Copy this file to .env and replace the placeholder with your actual API key
# docker-compose will automatically load variables from .env file
